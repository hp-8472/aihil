{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aihil.local/schemas/config.schema.json",
  "title": "AI-HIL project configuration",
  "description": "Schema for project-local .aihil/config.yaml files.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "default": "unknown-target"
        },
        "controller": {
          "type": "string",
          "default": "unknown-controller"
        }
      }
    },
    "debugger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "default": "openocd",
          "enum": [
            "openocd"
          ]
        },
        "executable": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "interface_cfg": {
          "type": "string",
          "default": "interface/stlink.cfg"
        },
        "target_cfg": {
          "type": "string",
          "default": "target/stm32f4x.cfg"
        },
        "timeout_s": {
          "type": "number",
          "default": 60.0
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_roots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "build"
          ]
        },
        "upload_directory": {
          "type": "string",
          "default": ".aihil/artifacts"
        },
        "allowed_extensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".elf",
            ".hex",
            ".bin"
          ]
        },
        "max_upload_size_mb": {
          "type": "integer",
          "default": 64
        },
        "allow_upload": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "com_ports": {
      "type": "object",
      "description": "Named serial/COM ports that AI-HIL may open for stimuli and feedback.",
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_.-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "device"
        ],
        "properties": {
          "device": {
            "type": "string",
            "description": "Host serial device, for example COM5 or /dev/ttyUSB0."
          },
          "baudrate": {
            "type": "integer",
            "minimum": 1,
            "default": 115200
          },
          "timeout_s": {
            "type": "number",
            "minimum": 0,
            "default": 0.1
          },
          "write_timeout_s": {
            "type": "number",
            "minimum": 0,
            "default": 1.0
          },
          "encoding": {
            "type": "string",
            "default": "utf-8"
          },
          "max_buffer_bytes": {
            "type": "integer",
            "minimum": 1,
            "default": 65536
          },
          "max_write_bytes": {
            "type": "integer",
            "minimum": 1,
            "default": 4096
          }
        }
      },
      "default": {}
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "require_existing_file": {
          "type": "boolean",
          "default": true
        },
        "require_allowed_root": {
          "type": "boolean",
          "default": true
        },
        "require_allowed_extension": {
          "type": "boolean",
          "default": true
        },
        "compute_sha256": {
          "type": "boolean",
          "default": true
        },
        "inspect_known_formats": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_probe": {
          "type": "boolean",
          "default": true
        },
        "allow_flash": {
          "type": "boolean",
          "default": true
        },
        "allow_reset": {
          "type": "boolean",
          "default": true
        },
        "allow_com_read": {
          "type": "boolean",
          "default": true
        },
        "allow_com_write": {
          "type": "boolean",
          "default": true
        },
        "allow_raw_debugger_commands": {
          "type": "boolean",
          "default": false
        },
        "allow_mass_erase": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "reports": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "directory": {
          "type": "string",
          "default": ".aihil/reports"
        }
      }
    },
    "logs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "directory": {
          "type": "string",
          "default": ".aihil/logs"
        }
      }
    }
  }
}
