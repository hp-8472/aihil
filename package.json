{
  "name": "aihil",
  "version": "0.1.0",
  "description": "Generic hardware-in-the-loop debugger interface for AI agents",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hp-8472/aihil.git"
  },
  "bugs": {
    "url": "https://github.com/hp-8472/aihil/issues"
  },
  "homepage": "https://github.com/hp-8472/aihil#readme",
